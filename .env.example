# ====== Скопируйте этот файл в .env и заполните значения ======

# Токен бота от @BotFather (обязательно)
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram ID администраторов через запятую (узнать свой ID можно у @userinfobot)
ADMIN_IDS=123456789

# ====== ИИ (умные ответы). Если оставить пустым — бот работает по поиску в базе ======
# Бесплатный вариант: Groq (https://console.groq.com) — получите API-ключ бесплатно.
# ВАЖНО: на БЕСПЛАТНОМ PythonAnywhere ИИ работать НЕ будет (api.groq.com вне белого
# списка). Оставьте пусто для бесплатного тарифа; ключ нужен для локального запуска
# или платного тарифа Hacker.
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile

# Примеры других провайдеров (OpenAI-совместимые):
#   OpenRouter:  AI_BASE_URL=https://openrouter.ai/api/v1   AI_MODEL=meta-llama/llama-3.3-70b-instruct
#   OpenAI:      AI_BASE_URL=https://api.openai.com/v1       AI_MODEL=gpt-4o-mini

# ====== Webhook (нужно только для PythonAnywhere / хостинга через webhook) ======
# Придумайте секретную строку без пробелов (часть адреса webhook)
WEBHOOK_SECRET=pridumayte-svoy-sekret-123
# Ваш логин на PythonAnywhere (для адреса https://<логин>.pythonanywhere.com)
PA_USERNAME=
# Либо сразу полный адрес webhook (тогда PA_USERNAME можно не заполнять):
# WEBHOOK_URL=https://login.pythonanywhere.com/pridumayte-svoy-sekret-123

# Файлы (можно не менять)
KNOWLEDGE_FILE=knowledge.md
DB_FILE=bot.db
